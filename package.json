{
  "name": "bytewars",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.app.json --noEmit && tsc --project tsconfig.node.json --noEmit",
    "check": "pnpm test && pnpm typecheck && pnpm e2e",
    "lint": "eslint src",
    "e2e": "playwright test",
    "run:fixture": "vitest run tests/logic/run-fixture.test.ts --reporter=verbose"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "6.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.1",
    "jsdom": "^29.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
