{
  "name": "bytewars",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.app.json --noEmit && tsc --project tsconfig.node.json --noEmit",
    "check": "pnpm test && pnpm typecheck && pnpm lint && pnpm format:check && pnpm e2e",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "refresh-readme-artifacts": "pnpm refresh-readme-artifacts:generate && pnpm refresh-readme-artifacts:copy",
    "refresh-readme-artifacts:generate": "playwright test tests/e2e/readme-screenshots.spec.ts tests/e2e/chassis-preview.spec.ts",
    "refresh-readme-artifacts:copy": "node scripts/copy-readme-artifacts.mjs",
    "pages": "pnpm build && bash scripts/deploy.sh"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "6.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
